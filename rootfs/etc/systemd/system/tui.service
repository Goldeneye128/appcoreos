[Unit]
Description=AppCoreOS TUI
After=systemd-user-sessions.service
Before=getty.target
Conflicts=getty@ttyS0.service serial-getty@ttyS0.service

[Service]
ExecStart=/usr/lib/your-os/tui.sh
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/ttyS0
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
