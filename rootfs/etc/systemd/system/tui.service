[Unit]
Description=AppCoreOS TUI
After=network.target
Conflicts=getty@tty1.service serial-getty@ttyS0.service console-getty.service

[Service]
ExecStart=/usr/lib/your-os/tui.sh
Restart=always
RestartSec=1
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/ttyS0
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

[Install]
WantedBy=multi-user.target
